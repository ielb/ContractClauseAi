# ==============================================
# ContractClauseAI Environment Configuration Template
# Copy this file to .env and update the values
# ==============================================

# How to use:
# 1. Copy this file: cp config.template .env
# 2. Update the values below with your actual credentials
# 3. Never commit the .env file to version control

# Application Settings
NODE_ENV=development
PORT=3001
APP_NAME=ContractClauseAI
APP_VERSION=1.0.0

# Database Configuration (MongoDB)
# Local: mongodb://localhost:27017/contract-clause-ai
# Docker: mongodb://mongodb:27017/contract-clause-ai
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/contract-clause-ai
MONGODB_URI=mongodb://localhost:27017/contract-clause-ai
MONGODB_DATABASE=contract-clause-ai

# Redis Configuration
# Local: localhost
# Docker: redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AWS Configuration
# Get these from AWS IAM Console
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=contract-clause-ai-storage

# OpenAI Configuration
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# Authentication
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_token_secret_also_32_characters_minimum
JWT_REFRESH_EXPIRES_IN=7d

# Stripe Configuration (Optional)
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Email Configuration (Optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,png,jpg,jpeg

# Security
HELMET_ENABLED=true
BCRYPT_SALT_ROUNDS=12

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# ==============================================
# Development vs Production Notes:
# ==============================================
# 
# Development:
# - Use local MongoDB and Redis
# - Use relaxed CORS settings
# - Enable detailed logging
# 
# Production:
# - Use managed MongoDB (Atlas) and Redis
# - Restrict CORS origins
# - Use environment-specific secrets
# - Enable all security features 